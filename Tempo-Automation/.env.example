# Twilio (outbound SMS only)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890      # Twilio number
MY_PHONE_NUMBER=+1987654321          # your personal number

# Tempo
TEMPO_API_TOKEN=your-tempo-api-token
TEMPO_BASE_URL=https://api.tempo.io  # or https://api.eu.tempo.io

# Jira
JIRA_DOMAIN=yourcompany.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_ACCOUNT_ID=your-atlassian-account-id
JIRA_BOARD_ID=123

# Optional
DAILY_HOURS=7.5
PROMPT_HOUR=9
